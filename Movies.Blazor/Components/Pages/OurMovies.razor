        //copy file to temp location

    }
    private void Cancel()
    {
        newMovie = null;
        //delete temp folder
    }
    private async Task Save()
    {
        //copy file to wwwroot/images
        //delete temp
        //store the movie
    }
    private async Task CreateMovie()
    {
        newMovie = new();
        var result = await CompanyService.GetAllAsync();
        if (result.IsSuccess)
        {
            companyModels = result.Data.Select(c => new CompanyModel
            {
                Id = c.Id,
                Name = c.Name
            });
        }
    }
    protected override async Task OnInitializedAsync()
    {
        var result = await MovieService.GetAllAsync();
        if(result.IsSuccess)
        {
            movieModels = result.Data.Select(m => new MovieModel
            {
                Title = m.Title,
                Image = m.Image,
                Id = m.Id,
            });
        }
    }
}